{
  "metadata": [
    {
      "src": [
        {
          "files": [ "Rowles.LeanCorpus.csproj" ],
          "src": "../src/core/Rowles.LeanCorpus"
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "namespaceLayout": "nested",
      "memberLayout": "separatePages",
      "allowCompilationErrors": false,
      "includePrivateMembers": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "*.md", "toc.yml" ]
      },
      {
        "files": [ "tutorials/**.md", "tutorials/**/toc.yml", "tutorials/toc.yml" ]
      },
      {
        "files": [ "articles/**.md", "articles/toc.yml" ]
      },
      {
        "files": [ "benchmarks/*.md", "benchmarks/toc.yml" ]
      }
    ],
    "output": "site",
    "template": [ "default", "modern", "templates/leancorpus" ],
    "resource": [
      {
        "files": [ "assets/**" ]
      },
    ],
    "globalMetadata": {
      "_appTitle": "LeanCorpus",
      "_appName": "LeanCorpus",
      "_appFooter": "LeanCorpus: a fast, embeddable full-text search engine for .NET",
      "_enableSearch": true,
      "categoryLayout": "nested"
    }
  }
}
