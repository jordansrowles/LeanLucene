{{#apiIcon}}<img class="api-icon" src="{{_rel}}assets/api-icons/{{apiIcon}}" alt="{{apiIconAlt}}" title="{{apiIconAlt}}" loading="lazy">{{/apiIcon}}{{#apiModifierIcons}}<img class="api-icon api-modifier-icon" src="{{_rel}}assets/api-icons/{{icon}}" alt="{{alt}}" title="{{alt}}" loading="lazy">{{/apiModifierIcons}}{{#apiShowAccessIcon}}<img class="api-icon api-access-icon" src="{{_rel}}assets/api-icons/{{apiAccessIcon}}" alt="{{apiAccessIconAlt}}" title="{{apiAccessIconAlt}}" loading="lazy">{{/apiShowAccessIcon}}
